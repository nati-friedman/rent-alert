{
  "manifest_version": 3,
  "name": "Rent Alert",
  "version": "2.0",
  "description": "Helps you search for an apartment on facebook",
  "permissions": [
    "tabs",
    "notifications",
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "background": {
    "service_worker": "src/scripts/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "src/utils/side-panel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/groups/*"],
      "js": ["src/scripts/content.js"]
    }
  ]
}